{
  "name": "interviewmate-server",
  "version": "1.0.0",
  "description": "Backend server for InterviewMate AI interview practice platform",
  "type": "module",
  "main": "nodemon server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "dev:safe": "node scripts/start.js",
    "start": "node server.js",
    "start:safe": "node scripts/start.js",
    "test": "jest",
    "check-env": "node scripts/checkEnv.js",
    "setup": "node scripts/checkEnv.js && npm run dev",
    "generate-jwt": "node scripts/generateJWTSecret.js",
    "kill-port": "node scripts/killPort.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.0.1",
    "google-auth-library": "^10.3.0",
    "helmet": "^7.2.0",
    "hpp": "^0.2.3",
    "isomorphic-dompurify": "^2.28.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.11.0",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.10.1",
    "pdf-parse": "^2.4.5",
    "razorpay": "^2.9.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}